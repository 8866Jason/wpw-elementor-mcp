{
  "name": "wpw-elementor-mcp",
  "version": "2.1.0",
  "description": "MCP server for reading and modifying Elementor page data in a DDEV WordPress site",
  "type": "module",
  "main": "build/index.js",
  "bin": {
    "wpw-elementor-mcp": "./build/index.js"
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "dev": "npm run build && node build/index.js",
    "start": "node build/index.js"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/8866Jason/wpw-elementor-mcp.git"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "elementor",
    "wordpress",
    "ddev",
    "page-builder",
    "claude"
  ],
  "author": "8866Jason",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/8866Jason/wpw-elementor-mcp/issues"
  },
  "homepage": "https://github.com/8866Jason/wpw-elementor-mcp#readme",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.6.1",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0"
  }
}
